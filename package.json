{
  "name": "cue-ts",
  "version": "0.1.0",
  "description": "TypeScript parser for a subset of the CUE configuration language",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wasm/*": "./wasm/pkg/*"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check ./src"
  },
  "keywords": [
    "cue",
    "parser",
    "ast",
    "configuration"
  ],
  "author": "Logan Lindquist Land",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "wasm/pkg"
  ],
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "bun-types": "^1.3.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
